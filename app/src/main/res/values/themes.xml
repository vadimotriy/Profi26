<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Profi26" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/white</item>
        <item name="android:windowSplashScreenBackground">@color/deep_blue</item>
        <item name="colorOnBackground">@color/white</item>
        <item name="colorOnSurface">@color/black</item>
        <item name="colorOnSecondary">@color/black60</item>
        <item name="colorOnSecondaryContainer">@color/dark20</item>
        <item name="colorOnPrimary">@color/dark05</item>

        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.Splash" parent="Base.Theme.Profi26">
        <item name="android:windowBackground">@color/deep_blue</item>
    </style>
    <!-- Base application theme. -->
    <style name="Base.Base.Theme.Profi26" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Base.Theme.Profi26.AppWidgetContainerParent" parent="@android:style/Theme.DeviceDefault">
        <!-- Radius of the outer bound of widgets to make the rounded corners -->
        <item name="appWidgetRadius">16dp</item>
        <!--
        Radius of the inner view's bound of widgets to make the rounded corners.
        It needs to be 8dp or less than the value of appWidgetRadius
        -->
        <item name="appWidgetInnerRadius">8dp</item>
    </style>

    <style name="Base.Theme.Profi26.AppWidgetContainer" parent="Base.Theme.Profi26.AppWidgetContainerParent">
        <!-- Apply padding to avoid the content of the widget colliding with the rounded corners -->
        <item name="appWidgetPadding">16dp</item>
    </style>
</resources>